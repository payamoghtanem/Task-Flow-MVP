# TaskFlow Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git — it is in .gitignore.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/taskflow

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── JWT (RS256) ──────────────────────────────────────────────────────────────
# Generate a 2048-bit RSA key pair:
#   openssl genrsa -out private.key 2048
#   openssl rsa -in private.key -pubout -out public.key
# Base64-encode for env var storage:
#   base64 -w0 private.key   # Linux
#   base64 -i private.key    # macOS
JWT_PRIVATE_KEY_BASE64=<base64_encoded_rsa_private_key>
JWT_PUBLIC_KEY_BASE64=<base64_encoded_rsa_public_key>
# Access token lifetime (≤15m enforced per security-standards.md SEC-006)
JWT_ACCESS_EXPIRY=15m
